// API キー設定のテンプレート。
// このファイルを `Secrets.xcconfig` にコピーし、実際の値を設定してください。
// `Secrets.xcconfig` は .gitignore 済みで、リポジトリ/履歴に実キーが残りません。
//
//   cp Secrets.example.xcconfig Secrets.xcconfig
//   # その後 Secrets.xcconfig を編集
//
// 値は Info.plist の $(GOOGLE_BOOKS_API_KEY) 等で参照されます。
// 注意: クライアント同梱の値はビルド成果物(IPA)に埋め込まれ、完全には秘匿できません。
// 本番ではバックエンドプロキシ経由が推奨です。

GOOGLE_BOOKS_API_KEY =
RAKUTEN_APP_ID =
RAKUTEN_ACCESS_KEY =
